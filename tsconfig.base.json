{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@cyoa/engine": ["packages/engine/src/index.ts"],
      "@cyoa/engine/*": ["packages/engine/src/*"],
      "@cyoa/shared": ["packages/shared/src/index.ts"],
      "@cyoa/shared/*": ["packages/shared/src/*"],
      "@cyoa/stories": ["packages/stories/src/index.ts"],
      "@cyoa/stories/*": ["packages/stories/src/*"]
    }
  }
}
