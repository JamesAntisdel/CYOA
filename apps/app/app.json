{
  "expo": {
    "name": "CYOA",
    "slug": "cyoa",
    "version": "0.1.0",
    "scheme": "cyoa",
    "platforms": ["ios", "android", "web"],
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/design/marketing/favicon-512.png",
    "splash": {
      "image": "./assets/design/marketing/favicon-512.png",
      "resizeMode": "contain",
      "backgroundColor": "#efe2c8"
    },
    "ios": {
      "bundleIdentifier": "com.cyoa.unwritten",
      "buildNumber": "1",
      "supportsTablet": true
    },
    "android": {
      "package": "com.cyoa.unwritten",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/design/marketing/favicon-512.png",
        "backgroundColor": "#efe2c8"
      },
      "permissions": []
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/design/marketing/favicon-32.png"
    },
    "plugins": ["expo-router"]
  }
}
