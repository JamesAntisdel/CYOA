# Copy to .env for Docker Compose local development.
# Do not put live secrets in this file or commit .env.

NODE_ENV=development

# Public browser origin. For local Docker use http://localhost:8081.
# For Cloudflare Tunnel HTTPS testing, set this to the tunnel URL.
PUBLIC_APP_URL=http://localhost:8081

# Cloudflare Named Tunnel token. Get it from Cloudflare Zero Trust:
# Networks → Tunnels → Create → Install connector → Docker tab.
# Leave blank to skip — the `tunnel` compose profile is opt-in.
CLOUDFLARE_TUNNEL_TOKEN=

# Client -> Convex. Use the URL printed by `pnpm dev:convex` or a personal Convex dev deployment.
# For tunnel testing from another device, do not leave this as localhost.
EXPO_PUBLIC_CONVEX_URL=http://localhost:3210
# Convex HTTP/site URL. Cloud Convex URLs usually end in .site and host BetterAuth routes.
EXPO_PUBLIC_CONVEX_SITE_URL=http://localhost:3211
CONVEX_DEPLOYMENT=

# Local non-billable provider mock service.
PROVIDER_MOCKS_PORT=4010
PROVIDER_MOCKS_URL=http://provider-mocks:4010
# For tunnel testing from another device, expose providers through their own tunnel host or leave
# mock-only features off. localhost works only when the browser is on this machine.
EXPO_PUBLIC_PROVIDER_MOCKS_URL=http://localhost:4010
MOCK_PROVIDER_MODE=ok
# Set to 503 to force provider mock errors.
MOCK_PROVIDER_STATUS=

# Optional future provider endpoint overrides for local/E2E tooling.
ANTHROPIC_BASE_URL=http://provider-mocks:4010/anthropic
VERTEX_BASE_URL=http://provider-mocks:4010/vertex
DEEPSEEK_BASE_URL=http://provider-mocks:4010/deepseek

# Real provider keys are not required for default local development.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
VERTEX_ACCESS_TOKEN=
VERTEX_TEXT_MODEL=gemini-2.5-flash
GOOGLE_APPLICATION_CREDENTIALS=
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
# Cloud TTS lives at texttospeech.googleapis.com — AI Studio Gemini keys
# can't call it. Mint a separate API key in Google Cloud Console with the
# "Cloud Text-to-Speech API" enabled. Leave blank to disable narration.
GOOGLE_CLOUD_TTS_API_KEY=
# Imagen via the public Gemini API. Requires GEMINI_API_KEY above. Falls
# back to the Vertex Imagen path when VERTEX_PROJECT_ID + VERTEX_ACCESS_TOKEN
# are set. With neither, scene-media uses a deterministic Picsum
# placeholder so dev still shows a picture.
GEMINI_IMAGE_MODEL=imagen-3.0-generate-002
GEMINI_VEO_MODEL=veo-3.1-lite-generate-preview
# Lite supports 4/6/8s at 720p. 1080p is 8s only.
GEMINI_VEO_DURATION_MS=4000
GEMINI_VEO_RESOLUTION=720p
GEMINI_VEO_ASPECT_RATIO=16:9
GEMINI_VEO_ESTIMATED_CENTS_PER_SECOND=5
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
LLM_TIMEOUT_MS=15000

# Narrator TTS provider is not yet wired in the backend (the client voice
# picker stores a chosen voice id but no TTS call happens). When TTS lands
# (Vertex AI TTS, Google Cloud TTS, or ElevenLabs), add the matching
# provider env keys here AND to packages/shared/src/env/index.ts. For now
# the picker is a UI scaffold only.

# Sensitive credentials (App Store Server API key, Google Play service
# account JSON, EAS token, CONVEX_DEPLOY_KEY, VERTEX_SERVICE_ACCOUNT_JSON)
# MUST live in Vault — not in this file. See `scripts/secrets/
# check-local-env.mjs` SENSITIVE_KEYS for the full guarded list.

# Stripe sandbox placeholders for local Docker shape only.
# Do not put real Stripe keys here. Store real keys in Vault and sync Convex from Vault.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_FORWARD_URL=http://host.docker.internal:3210/stripe/webhook
STRIPE_PRICE_UNLIMITED_MONTHLY=
STRIPE_PRICE_UNLIMITED_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
EXPO_PUBLIC_STRIPE_CHECKOUT_MODE=web

# BetterAuth local/tunnel values. Store real values in Vault and sync Convex from Vault.
# In Convex-backed auth, set BETTER_AUTH_SECRET, SITE_URL, and JWKS on the Convex deployment
# with `convex env set`, not only in this local Compose env file.
BETTER_AUTH_SECRET=replace-with-a-local-random-string
BETTER_AUTH_URL=http://localhost:8081
SITE_URL=http://localhost:8081
# Static JWKS can be generated after BetterAuth schema/functions are live:
# npx convex run auth:generateJwk | npx convex env set JWKS
# Local dev placeholder. Replace with generated JWKS for real BetterAuth deployments.
JWKS=[]
# local uses the in-app development adapter. better-auth is reserved for the server route adapter.
EXPO_PUBLIC_AUTH_MODE=local

# Optional fake object storage profile.
S3_ENDPOINT=http://object-storage:9000
S3_ACCESS_KEY_ID=cyoa-local
S3_SECRET_ACCESS_KEY=cyoa-local-password
S3_BUCKET=cyoa-local-assets

# Native app store products. These IDs must match App Store Connect and Google Play Console.
APPLE_PRODUCT_UNLIMITED_MONTHLY=cyoa_unlimited_monthly
APPLE_PRODUCT_PRO_MONTHLY=cyoa_pro_monthly
GOOGLE_PRODUCT_UNLIMITED_MONTHLY=cyoa_unlimited_monthly
GOOGLE_PRODUCT_PRO_MONTHLY=cyoa_pro_monthly

# omni-cinematics master switch. "1"/"true" to enable Gemini Omni endpoint
# cinematics for Pro readers; unset/0 = dark (per_scene_legacy). Needs GEMINI_API_KEY.
OMNI_ENABLED=0
# GEMINI_OMNI_MODEL=gemini-omni-flash-preview
