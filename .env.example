# Copy to .env for Docker Compose local development.
# Do not put live secrets in this file or commit .env.

NODE_ENV=development

# Client -> Convex. Use the URL printed by `pnpm dev:convex` or a personal Convex dev deployment.
EXPO_PUBLIC_CONVEX_URL=http://localhost:3210
CONVEX_DEPLOYMENT=

# Local non-billable provider mock service.
PROVIDER_MOCKS_PORT=4010
PROVIDER_MOCKS_URL=http://provider-mocks:4010
EXPO_PUBLIC_PROVIDER_MOCKS_URL=http://localhost:4010
MOCK_PROVIDER_MODE=ok
# Set to 503 to force provider mock errors.
MOCK_PROVIDER_STATUS=

# Optional future provider endpoint overrides for local/E2E tooling.
ANTHROPIC_BASE_URL=http://provider-mocks:4010/anthropic
VERTEX_BASE_URL=http://provider-mocks:4010/vertex
DEEPSEEK_BASE_URL=http://provider-mocks:4010/deepseek

# Real provider keys are not required for default local development.
ANTHROPIC_API_KEY=
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=
DEEPSEEK_API_KEY=

# Stripe sandbox. Use test keys only.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_FORWARD_URL=http://host.docker.internal:3210/stripe/webhook

# BetterAuth local-only values.
BETTER_AUTH_SECRET=replace-with-a-local-random-string
BETTER_AUTH_URL=http://localhost:8081

# Optional fake object storage profile.
S3_ENDPOINT=http://object-storage:9000
S3_ACCESS_KEY_ID=cyoa-local
S3_SECRET_ACCESS_KEY=cyoa-local-password
S3_BUCKET=cyoa-local-assets
